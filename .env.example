
 # Set the maximum number of files allowed in a single request.
 MAX_FILES_PER_REQUEST=20
 # Set the maximum upload size allowed for each file in megabytes.
 MAX_FILE_SIZE_MB=10
 # Set the rembg model used for background removal.
 REMBG_MODEL_NAME=u2net_cloth_seg
 # Set the CLIP checkpoint used for zero-shot garment attributes.
 CLIP_MODEL_NAME=openai/clip-vit-base-patch32
 # Set the optional DeepFashion2 TorchScript checkpoint path.
 DEEPFASHION2_TORCHSCRIPT_PATH=
 # Set the minimum score a detector box must exceed before it is returned.
 DETECTOR_CONFIDENCE_THRESHOLD=0.35
 # Set the minimum score an attribute label must exceed before it is accepted.
 ATTRIBUTE_CONFIDENCE_THRESHOLD=0.25
 # Set whether the service should fall back to alpha-mask-plus-CLIP detection.
 ENABLE_CLIP_FALLBACK_DETECTOR=true

